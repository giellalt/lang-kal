  Punctuation  ; !!вүҲ - **@CODE@** 
  Symbols      ; !!вүҲ - **@CODE@** 
  numeralier   ; !!вүҲ - **@CODE@** 
  Forkortelser ; !!вүҲ - **@CODE@** 
  Akronymer    ; !!вүҲ - **@CODE@** 
