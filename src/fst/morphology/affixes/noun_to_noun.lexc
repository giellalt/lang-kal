! 20241004 nominalstammer, som kræver possessormarkering, begrænsning af overgenerering
! eliminerer generering af meningsløse ordformer til stavekontrollen

LEXICON poss_noun_schwa ! nominalstammer med stammefinal schwa, som kræver possessormarkering. Begrænset morfologi (misse, tunge).
+INNAQ+Der/nn:%>%VTRUNCaannaq simple_cases ;
+NNGUAQ+Der/nn:%>nnguaq Z1nnguaqZ ; 
+PIAQ+Der/nn:%>%VTRUNCarpiaq poss_noun_schwa_piaq_infl ;
+QQINNAAQ+Der/nn:qqinnaaq simple_cases ;
 poss_noun_schwa_infl ;

LEXICON poss_noun_schwa_infl
+N+Abs+Sg+3SgPoss:%>%VTRUNCaa # ; 
+N+Abs+Sg+3PlPoss:%>%VTRUNCaat # ; 
+N+Abs+Pl+3PlPoss:%>%VTRUNCaat # ;
+N+Rel+Sg+3SgPoss:%>%VTRUNCaata # ;
+N+Rel+Sg+3PlPoss:%>%VTRUNCaata # ;
+N+Rel+Pl+3SgPoss:%>%VTRUNCaasa # ;
+N+Rel+Pl+3PlPoss:%>%VTRUNCaasa # ;
+N+Lok+Sg+1PlPoss:%>%VTRUNCitsinni poss_noun_LokVb ;
+N+Lok+Sg+3SgPoss:%>%VTRUNCaani poss_noun_LokVb ;
+N+Lok+Pl+3SgPoss:%>%VTRUNCaani poss_noun_LokVb ;
+N+Lok+Sg+3PlPoss:%>%VTRUNCaanni poss_noun_LokVb ;
+N+Lok+Pl+3PlPoss:%>%VTRUNCaanni poss_noun_LokVb ;
+N+Ins+Sg+3SgPoss:%>%VTRUNCaanik # ;
+N+Ins+Pl+3SgPoss:%>%VTRUNCaanik # ;
+N+Ins+Sg+3PlPoss:%>%VTRUNCaannik # ;
+N+Ins+Pl+3PlPoss:%>%VTRUNCaannik # ;
+N+Trm+Sg+1SgPoss:%>%VTRUNCinnut poss_noun_enkl ;
+N+Trm+Pl+1SgPoss:%>%VTRUNCinnut poss_noun_enkl ;
+N+Trm+Pl+2SgPoss:%>%VTRUNCinnut poss_noun_enkl ;
+N+Trm+Sg+2SgPoss:%>%VTRUNCinnut poss_noun_enkl ;
+N+Trm+Sg+3SgPoss:%>%VTRUNCaanut poss_noun_enkl ;
+N+Trm+Pl+3SgPoss:%>%VTRUNCaanut poss_noun_enkl ;
+N+Trm+Sg+3PlPoss:%>%VTRUNCaannut # ;
+N+Trm+Pl+3PlPoss:%>%VTRUNCaannut # ;
+N+Trm+Sg+4SgPoss:%>%VTRUNCiminut # ;
+N+Trm+Pl+4SgPoss:%>%VTRUNCiminut # ;
+N+Via+Sg+3PlPoss:%>%VTRUNCaatigut # ;
+N+Via+Sg+3SgPoss:%>%VTRUNCaatigut # ;
+N+Via+Pl+3SgPoss:%>%VTRUNCaasigut # ;
+N+Via+Pl+3PlPoss:%>%VTRUNCaasigut # ;
+N+Abl+Sg+3SgPoss:%>%VTRUNCaanit # ;
+N+Abl+Sg+3SgPoss:%>%VTRUNCaaniit # ;
+N+Abl+Sg+3PlPoss:%>%VTRUNCaannit # ; !PL20251115 tilføjet
+N+Abl+Sg+3PlPoss:%>%VTRUNCaanniit # ; !PL20251115 tilføjet

LEXICON poss_noun_schwa_piaq_infl
+N+Ins+Sg+3PlPoss:^T%>annik # ;
+N+Ins+Pl+3PlPoss:^T%>annik # ;

LEXICON poss_noun_LokVb ! begrænsning af viderederivering af de såkaldte hybridverber
+Gram/Hyb+IP+Gram/IV:%>ip poss_noun_schwa_IP ;
 poss_noun_enkl ;
 # ;

LEXICON poss_noun_schwa_IP ! begrænsede muligheder for derivering efter IP
+GALLAR+Der/vv+Gram/IV:%>gallar poss_noun_schwa_nom ;
+GALUAR+Der/vv+Gram/IV:%>galuar poss_noun_schwa_nom ;
+LIR+Der/vv+Gram/IV:^T%>ler poss_noun_schwa_nom ;
+TAR+Der/vv+Gram/IV:%>tar poss_noun_schwa_nom ;
 poss_noun_schwa_nom ;
 simple_moods ;

LEXICON poss_noun_schwa_nom ! nominaliserende suffikser til deriverede former af nominalstammer som kræver possessormarkering, begrænsning af overgenerering
+NIQ+Der/vn:%>neq simple_cases ;
+TUQ+Der/vn:%>toq simple_cases ;
 simple_moods ;

LEXICON simple_moods ! leksikon uden derivative entries, begrænsning af overgenerering
+V+Ind+3Sg:%>poq # ;
+V+Ind+3Pl:%>put # ;
+V+Par+3Sg:%>toq # ;
+V+Par+3Pl:%>tut # ;

LEXICON simple_cases ! leksikon uden derivative entries, begrænsning af overgenerering
+N+Abs+Sg: # ;
+N+Abs+Sg+3SgPoss:^T%>a # ;
+N+Abs+Pl:^T%>t # ;
+N+Abs+Sg+3PlPoss:%>at # ;
+N+Trm+Sg+3SgPoss:%>%VTRUNCanut # ;
+N+Trm+Sg+1SgPoss:%>%VTRUNCannut # ;

LEXICON poss_noun_enkl
+LI:%CLITli # ;
 # ;

 
!spell flag section
!blocking suffix combinations to filter out suggestions from spellchecker

LEXICON araq_nn
< "@U.araq.ON@" > Z1+qaZmorf ;

LEXICON giit_nn
< "@U.Num.Pl@" "@U.ge.OFF@" > GIIT ;

LEXICON kuq_nn
< "@U.gunartuq.OFF@" "@U.gunnaarfik.OFF@" "@U.kuq.ON@" "@U.Tur.T@" > tp ;
!naleqqukkunnaarfikuupput

LEXICON lik_nn
< "@U.ge.OFF@" "@U.lik.ON@" > Z2+lZ ;

LEXICON laaq_nn
< "@U.Tur.T@" "@U.laaq.ON@" > tp ;

LEXICON nnaaq_nn ! +NNAAQ+Der/nn
< "@U.nnaaq.ON@" > tp ;
!malinnaaviaqineqarlutik

LEXICON ssaq_nn ! +SSAQ+Der/nn
< "@U.ssaq.ON@" > tp ;
!atorneqarsinnaassangalluarami

LEXICON ute_nn 
< "@U.utenn.ON@" > tpt ;

LEXICON vik_nn ! +VIK/Der/nn
< "@U.nip.OFF@" "@U.nngur.OFF@" "@U.vik.ON@" > tup- ;
!malinnaavineqineqarlutik
