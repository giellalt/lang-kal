+N+Lok+Sg+3SgPoss:^VT%>aani poss_noun_LokVb ;
+N+Lok+Pl+3SgPoss:^VT%>aani poss_noun_LokVb ;
+N+Lok+Sg+3PlPoss:^VT%>aanni poss_noun_LokVb ;
+N+Lok+Pl+3PlPoss:^VT%>aanni poss_noun_LokVb ;
+N+Ins+Sg+3SgPoss:^VT%>aanik # ;
+N+Ins+Pl+3SgPoss:^VT%>aanik # ;
+N+Ins+Sg+3PlPoss:^VT%>aannik # ;
+N+Ins+Pl+3PlPoss:^VT%>aannik # ;
+N+Trm+Sg+1SgPoss:^VT%>innut poss_noun_enkl ;
+N+Trm+Pl+1SgPoss:^VT%>innut poss_noun_enkl ;
+N+Trm+Pl+2SgPoss:^VT%>innut poss_noun_enkl ;
+N+Trm+Sg+2SgPoss:^VT%>innut poss_noun_enkl ;
+N+Trm+Sg+3SgPoss:^VT%>aanut poss_noun_enkl ;
+N+Trm+Pl+3SgPoss:^VT%>aanut poss_noun_enkl ;
+N+Trm+Sg+3PlPoss:^VT%>aannut # ;
+N+Trm+Pl+3PlPoss:^VT%>aannut # ;
+N+Trm+Sg+4SgPoss:^VT%>iminut # ;
+N+Trm+Pl+4SgPoss:^VT%>iminut # ;
+N+Via+Sg+3PlPoss:^VT%>aatigut # ;
+N+Via+Sg+3SgPoss:^VT%>aatigut # ;
+N+Via+Pl+3SgPoss:^VT%>aasigut # ;
+N+Via+Pl+3PlPoss:^VT%>aasigut # ;
+N+Abl+Sg+3SgPoss:^VT%>aanit # ;
+N+Abl+Sg+3SgPoss:^VT%>aaniit # ;
+N+Abl+Sg+3PlPoss:^VT%>aannit # ; !PL20251115 tilføjet
+N+Abl+Sg+3PlPoss:^VT%>aanniit # ; !PL20251115 tilføjet

LEXICON poss_noun_schwa_piaq_infl
+N+Ins+Sg+3PlPoss:^T%>annik # ;
+N+Ins+Pl+3PlPoss:^T%>annik # ;

LEXICON poss_noun_LokVb ! begrænsning af viderederivering af de såkaldte hybridverber
+Gram/Hyb+IP+Gram/IV:%>ip poss_noun_schwa_IP ;
 poss_noun_enkl ;
 # ;

LEXICON poss_noun_schwa_IP ! begrænsede muligheder for derivering efter IP
+GALLAR+Der/vv+Gram/IV:%>gallar poss_noun_schwa_nom ;
+GALUAR+Der/vv+Gram/IV:%>galuar poss_noun_schwa_nom ;
+LIR+Der/vv+Gram/IV:^T%>ler poss_noun_schwa_nom ;
+TAR+Der/vv+Gram/IV:%>tar poss_noun_schwa_nom ;
 poss_noun_schwa_nom ;
 simple_moods ;

LEXICON poss_noun_schwa_nom ! nominaliserende suffikser til deriverede former af nominalstammer som kræver possessormarkering, begrænsning af overgenerering
+NIQ+Der/vn:%>neq simple_cases ;
+TUQ+Der/vn:%>toq simple_cases ;
 simple_moods ;

LEXICON simple_moods ! leksikon uden derivative entries, begrænsning af overgenerering
+V+Ind+3Sg:%>poq # ;
+V+Ind+3Pl:%>put # ;
+V+Par+3Sg:%>toq # ;
+V+Par+3Pl:%>tut # ;

LEXICON simple_cases ! leksikon uden derivative entries, begrænsning af overgenerering
+N+Abs+Sg: # ;
+N+Abs+Sg+3SgPoss:^T%>a # ;
+N+Abs+Pl:^T%>t # ;
+N+Abs+Sg+3PlPoss:%>at # ;
+N+Trm+Sg+3SgPoss:^VT%>anut # ;
+N+Trm+Sg+1SgPoss:^VT%>annut # ;

LEXICON poss_noun_enkl
+LI:^CLITli # ;
 # ;

 
!spell flag section
!blocking suffix combinations to filter out suggestions from spellchecker

LEXICON araq_nn
< "@U.araq.ON@" > Z1+qaZmorf ;

LEXICON giit_nn
< "@U.Num.Pl@" "@U.ge.OFF@" > GIIT ;

LEXICON kuq_nn
< "@U.gunartuq.OFF@" "@U.gunnaarfik.OFF@" "@U.kuq.ON@" "@U.Tur.T@" > tp ;
!naleqqukkunnaarfikuupput

LEXICON lik_nn
< "@U.ge.OFF@" "@U.lik.ON@" > Z2+lZ ;

LEXICON laaq_nn
< "@U.Tur.T@" "@U.laaq.ON@" > tp ;

LEXICON nnaaq_nn ! +NNAAQ+Der/nn
< "@U.nnaaq.ON@" > tp ;
!malinnaaviaqineqarlutik

LEXICON ssaq_nn ! +SSAQ+Der/nn
< "@U.ssaq.ON@" > tp ;
!atorneqarsinnaassangalluarami

LEXICON ute_nn 
< "@U.utenn.ON@" > tpt ;

LEXICON vik_nn ! +VIK/Der/nn
< "@U.nip.OFF@" "@U.nngur.OFF@" "@U.vik.ON@" > tup- ;
!malinnaavineqineqarlutik


