! 20241004 nominalstammer, som kræver possessormarkering, begrænsning af overgenerering
! eliminerer generering af meningsløse ordformer til stavekontrollen

LEXICON poss_noun_schwa ! nominalstammer med stammefinal schwa, som kræver possessormarkering. Begrænset morfologi (misse, tunge).
+INNAQ+Der/nn:^VT%>aannaq simple_cases ;
+NNGUAQ+Der/nn:%>nnguaq Z1nnguaqZ ; 
+PIAQ+Der/nn:^VT%>arpiaq poss_noun_schwa_piaq_infl ;
+QQINNAAQ+Der/nn:qqinnaaq simple_cases ;
 poss_noun_schwa_infl ;

LEXICON poss_noun_schwa_infl
+N+Abs+Sg+3SgPoss:^VT%>aa # ; 
+N+Abs+Sg+3PlPoss:^VT%>aat # ; 
+N+Abs+Pl+3PlPoss:^VT%>aat # ;
