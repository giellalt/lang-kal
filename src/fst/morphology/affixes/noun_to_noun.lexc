!NOMINERNES PARADIGMER
!tp for arnaq etc.
!tp_uden_derivativer for pi, der skal direkte til fleksiverne
!tpt for angut etc.
!Z1+ssZ for aagiaq etc.
!tup- for atuarfik og innaq
!tup for erneq
!og gammel saarullik


LEXICON GEMS !!= * @CODE@ = Gennemgangsleksikon til nominer der geminerer til stop-lyd ved fleksion, fx meeqqap
0:^GEMS Z1Zmorf ; !!= * @CODE@

LEXICON Z1Zmorf !!= * @CODE@ Derivationsmorfemer til nominer, viser til **tp** og giver derefter nn-derivationer
!!= * @CODE@ obs 20200623: fleksionsmorfemgrænse er %< og ikke %>
< "@C.riartoq@" > Z1Zmorf_nn_suffixes ;
tp ;

LEXICON tp !!= * @CODE@ obs 20200623: fleksionsmorfemgrænse er %< og ikke %>
< "@C.Loan.i@" > weak_stem_verbalizers ;
 tp_infl ;

