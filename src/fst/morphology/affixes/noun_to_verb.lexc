< "@U.Num.Pl@" > HTR_longV_GAQ_addi ;

LEXICON liar_iv
< "@U.usiq.OFF@" > IV_r_UTE_gennemgang ;

LEXICON lir_tv
< "@U.ja.OFF@" "@U.qqa.OFF@" "@U.qqar.OFF@" "@U.tirtv.OFF@" "@U.usiq.OFF@" "@U.lirtv.ON@" > HTR_ir_GAQ_i ;

LEXICON lir_iv
< "@U.usiq.OFF@" > XIirXmorf_stem ;

LEXICON liri_iv
< "@U.liri.ON@" > XIi_voqXmorf ;

LEXICON lirsur_iv
< "@C.Num@" "@U.lirsur.ON@" > IV_r_UTE_gennemgang ;

LEXICON lirsur_tv
