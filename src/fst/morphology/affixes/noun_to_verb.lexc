@U.Boole.On@+GUP+Der/nv:@U.Boole.On@g2up IV_k_stem ; !Boole forhindrer *mamakujuttoruppoq
@D.aak.ON@+LUP+Der/nv:@D.aak.ON@lup lup_nv ; !IV_k_stem
+SI+Der/nv:si si_nv ; ! XIi_voqXmorf
+SIUR+Der/nv:sior IV_r ;
+SIUR+Der/nv+UTE+Der/vv@U.saar.OFF@:@U.saar.OFF@siuup HTR_UTE_SSAQ_ssi ;
+SUNNIP+Der/nv:sunnip IV_k ;
+SUNNIP+Der/nv:sunnip XItsX ;
@D.qimmeq.ON@+TAAR+Der/nv:@D.qimmeq.ON@taar IV_r ;
+TAAR+Der/nv+Orth/Youth+Use/-Spell:rtaar IV_r ;
+TU+Der/nv:tu tu_iv ; ! IV_voq
@C.Num@@U.Tur.Off@+TUR+Der/nv:@C.Num@@U.Tur.Off@tor tur_iv ; ! IV_r
@C.Num@@U.Tur.On@+TUR+Der/nv:@C.Num@@U.Tur.On@sor tur_iv ; ! IV_r
@C.Num@+TUR+Der/nv+GUMA+Der/vv:@C.Num@tuuma IV_r ; !241019 PN. Ved ikke om det er i orden sådan.

LEXICON recessive_weak_stem_verbalizers !recessive consonant appears when suffixed to vowel stems
+PALLAP+Der/nv:r2pallap IV_k ;
+PALAAQ+Der/vn+U+Der/nv:r2palaa IV_voq ; !For at faa baade palaavoq og palaajuvoq
