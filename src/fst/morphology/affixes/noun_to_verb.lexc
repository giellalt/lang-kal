!# Der/nv #!
!##########!

LEXICON copula_nv
< "@C.nnguaq@" "@U.alup.OFF@" "@U.ja.OFF@" "@U.nar.OFF@" "@U.nga.OFF@" "@U.qqar.OFF@" "@U.saar.OFF@" "@U.umi.OFF@" "@U.copula.ON@" > IV_voq ;

LEXICON ge_nv
< "@U.saar.OFF@" "@U.ge.ON@" > HTR_schwa_SAQ_nnip ;

LEXICON giip_nv
< "@U.giip.ON@" "@U.Num.Pl@" > XIiXmorf_stem ;

LEXICON gip_nv
< "@U.iar.OFF@" "@U.niaq.OFF@" "@U.gip.ON@" > XIiXmorf_stem ;

LEXICON iar_tv ! +IAR+Der/nv
< "@U.iar.ON@" > HTR_r_GAQ_i ;
! noun stem +IAR+Der/nv not to be combined with suffix indicated in OFF flag in stem
!malinnaaviaqineqarlutik

LEXICON irsir_iv 
< "@U.irsir.ON@" > XIirXmorf_stem ;

LEXICON irute_iv
< "@U.saar.OFF@" > XIuteXmorf ;

LEXICON irute_tv
< "@U.saar.OFF@" > HTR_UTE_SSAQ_ssi ;

